@charset "utf-8";

div.colorPicker-picker { height: 16px; width: 16px; margin: 0px 2px 5px 0px; border: 1px solid rgb(204, 204, 204); background: url("/img/picker.gif") right top no-repeat; cursor: pointer; line-height: 16px; display: inline-block; padding: 0px !important; }

div.colorPicker-palette { width: 110px; position: absolute; border: 1px solid rgb(89, 143, 239); background-color: rgb(239, 239, 239); padding: 2px; z-index: 9999; }

div.colorPicker_hexWrap { width: 100%; float: left; }

div.colorPicker_hexWrap label { font-size: 95%; color: rgb(47, 47, 47); margin: 5px 2px; width: 25%; }

div.colorPicker_hexWrap input { margin: 5px 2px; padding: 0px; font-size: 95%; border: 1px solid rgb(0, 0, 0); width: 65%; }

div.colorPicker-swatch { height: 12px; width: 12px; border: 1px solid rgb(0, 0, 0); margin: 2px; float: left; cursor: pointer; line-height: 12px; }
