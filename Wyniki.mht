------MultipartBoundary--pE7yK9UzOwSW2Mhg8hV4LRazYZTawZ2GrXQ8oNEtnc----
Content-Type: text/css
Content-Transfer-Encoding: binary
Content-Location: https://multipasko.ovh/css/mapy11.css?t=202401192233

@charset "utf-8";

body { font-family: Verdana, Arial, Helvetica, sans-serif; margin: 0px; background: rgb(6, 103, 0); text-size-adjust: none; }

.left { float: left; }

ul { padding: 10px 0px 0px 20px; margin: 0px; }

ul li { margin: 5px 0px; }

h4 { margin: 0px; }

h2 { margin: 7px 0px; color: rgb(255, 255, 0); padding: 15px; background: rgb(0, 85, 0); }

#main { font-size: 13px; }

input, select { font-size: 16px; padding: 5px; }

#history { background: rgb(221, 221, 221); padding: 10px; margin: 10px; width: 803px; }

#history a { color: rgb(0, 0, 255); }

#history a:hover { font-size: 14px; font-weight: bold; }

a { color: rgb(255, 255, 51); }

form a { color: rgb(0, 0, 255); line-height: 20px; padding: 10px; }

#logo_multipasko { display: block; width: 400px; height: 80px; margin-top: 25px; margin-left: 100px; }

#head { background: url("/img/logomapy2.jpg") no-repeat transparent; height: 188px; margin: 0px; }

#topcenter { padding: 0px; vertical-align: top; width: 545px; text-align: center; float: left; }

#topcenter h1 { font-size: 13px; text-align: right; font-family: verdana; letter-spacing: 1px; color: rgb(221, 255, 221); line-height: 22px; margin: 0px; padding: 10px 45px 0px 0px; }

table { margin: 20px 40px 20px 0px; border-collapse: collapse; empty-cells: hide; float: left; }

.abovetable { color: rgb(255, 255, 255); margin: 5px 0px; padding: 15px; background: rgb(0, 85, 0); font-size: 14px; line-height: 25px; }

#divbanner { margin: 20px 0px 0px 5px; overflow: auto; width: 1320px; padding-bottom: 12px; }

#divbanner .first { float: left; margin: 8px 0px 5px; }

#divbanner .second { float: left; margin: 10px 20px; width: 280px; }

#divbanner .third { float: left; margin: 8px 0px; }

.mapWylosowano { background: rgb(239, 220, 14); border-color: rgb(239, 220, 14); color: rgb(0, 0, 0); }

.mapyNumer { background: rgb(51, 51, 51); color: rgb(187, 187, 187); border-color: rgb(119, 119, 119); border-style: dashed; border-width: 1px; line-height: 15px; white-space: nowrap; position: relative; text-align: center; cursor: pointer; font-size: 11px !important; padding: 0px 5px !important; }

table td { border: 1px solid rgb(107, 107, 107); background: rgb(51, 102, 0); font-family: tahoma, arial, verdana; font-size: 11px; color: rgb(139, 139, 139); }

table.m2 td { color: rgb(51, 102, 0); }

#stopka { clear: both; margin-top: 0px; padding: 8px 0px 125px; text-align: center; font: 18px verdana; color: rgb(255, 255, 255); background-color: rgb(51, 102, 0); }

#stopka span { margin-left: 15px; }

#stopka img { height: 64px; position: relative; top: 10px; }

fieldset { padding: 8px 10px; margin: 0px; border: 2px solid rgb(153, 153, 153); background: rgb(204, 204, 204); }

legend { font-size: 18px; font-weight: bold; color: rgb(0, 0, 204); margin: 2px 10px; }

label { margin: 5px; }

#main .plus { background-color: rgb(102, 153, 204); border-color: rgb(102, 153, 204); color: rgb(0, 0, 0); }

form { width: 828px; margin-left: 5px; float: left; background: rgb(221, 221, 221); }

#lf form { width: 240px; padding: 20px; margin: 0px; font-size: 13px; float: none; }

#lf label:first-child { margin-left: 13px; }

#lf a { padding: 0px; }

form p { padding: 5px; margin: 7px; background: rgb(204, 204, 85); border: 1px solid rgb(0, 0, 0); float: left; }

p.kolory { width: 155px; }

div.kolory { float: left; margin: 20px 40px 0px; padding: 5px; background: rgb(0, 68, 0); border: 2px solid rgb(51, 187, 51); color: rgb(255, 255, 255); font-size: 13px; width: 170px; height: 44px; overflow: hidden; }

.kolory label { margin: 2px; }

#adkontekst { float: left; width: 336px; margin: 5px 0px 10px 10px; }

#lf h3 { text-align: center; margin-top: 0px; margin-bottom: 10px; font-size: 18px; color: gold; }

.uwaga { background: rgb(255, 255, 51); color: rgb(0, 0, 255); margin: 20px 0px 0px; padding: 5px; font-size: 13px; font-weight: bold; clear: both; text-align: center; }

div.form-container { margin: 10px; padding: 5px; background-color: rgb(255, 255, 255); }

p.legend { margin-bottom: 1em; }

p.legend em { color: rgb(204, 0, 0); font-style: normal; }

div.form-container div.controlset { display: block; float: left; width: 100%; padding: 0.25em 0px; }

div.form-container div.controlset label, div.form-container div.controlset input, div.form-container div.controlset div { display: inline; float: left; }

div.form-container div.controlset label { width: 100px; }

#generowanie { clear: both; text-align: center; padding: 10px 0px; }

#generowanie input { font-size: 15px; padding: 10px; font-weight: bold; cursor: pointer; border: 2px solid rgb(68, 153, 68); border-radius: 8px; margin: 10px; }

#generowanie a { color: rgb(0, 0, 255); font-size: 16px; font-weight: bold; }

#lf input { margin-bottom: 5px; padding: 2px 5px; line-height: 18px; width: 140px; }

#lf input[type="checkbox"] { width: auto; }

#lf a { font-size: 13px; }

#lf > div { padding: 5px 15px; text-align: center; width: 250px; background: rgb(221, 221, 221); font-size: 14px; }

#lf div.fb-login-button { height: 38px; line-height: 38px; padding: 0px; }

#lf a.button { margin: 3px 0px 8px 5px; width: 90px; display: inline-block; height: 18px; line-height: 18px; padding: 3px 5px; text-align: center; }

h3.zestawy-header { text-align: center; font-size: 15px; margin-bottom: 10px; }

#lf-zapomnij { vertical-align: middle; }

input[type="submit"], input[type="button"], a.button { background: rgb(221, 221, 221); color: rgb(0, 0, 170); border: 2px solid rgb(68, 153, 68); padding: 5px; border-radius: 7px; cursor: pointer; font-size: 11px; text-decoration: none; }

.clear { clear: both; }

#aktualne-typowania { display: none; }

.center { text-align: center; }

.box1 { margin: 0px 10px 10px; background: rgb(175, 65, 65); color: rgb(252, 251, 238); padding: 8px 15px; font-size: 15px; font-family: Arial, sans-serif; line-height: 140%; border: 1px solid rgb(198, 216, 128); }

.box1 a { color: rgb(255, 255, 0) !important; }

.googleads { margin: 20px 0px; position: relative; padding-top: 27px; }

.hidden { display: none; }

.addnew td { display: none; cursor: pointer; height: 16px; }

.addnew td.mapyNumer { display: table-cell; }

#custom-fb-login { background-color: rgb(66, 103, 178); color: white; font-size: 16px; font-family: Arial, sans-serif; font-weight: bold; margin-top: 10px; padding: 10px 5px; border-width: medium; border-style: none; border-color: currentcolor; border-image: none; border-radius: 5px; cursor: pointer; display: inline-block; text-align: center; text-decoration: none; width: 100%; max-width: 300px; box-shadow: rgba(0, 0, 0, 0.2) 0px 2px 5px; }

#custom-fb-login:hover { background-color: rgb(54, 88, 153); }

#custom-fb-login:focus { outline: none; }

@media print {
  #head, #divbanner, #adkontekst, #adsense-bottom, a, span { display: none; }
  #stopka span { display: inline; }
  * { background: rgb(255, 255, 255) !important; color: rgb(0, 0, 0) !important; }
  body { background: rgb(255, 255, 255); }
  h2 { margin-bottom: 20px; }
  body div { display: none; }
  body #main, body #main h2 { display: block; margin: 0px; padding: 0px 10px; }
  body #main > * { display: none; }
  body #main table { display: table; float: none; }
  body #stopka { display: block; font-size: 24px; border-style: solid; border-color: rgb(153, 153, 153); border-image: none; border-width: 1px 0px; padding-bottom: 10px; }
  table td { background: rgb(255, 255, 255); color: rgb(0, 0, 0); }
  table td { border-color: rgb(204, 204, 204); padding: 10px; font-size: 0px !important; }
  table td.mapWylosowano { visibility: inherit; border-color: rgb(204, 204, 204); font-size: 13px !important; }
  #main table td.mapWylosowano.plus { font-weight: bold; }
  table td.mapyNumer { font-size: 10px !important; }
  #cmpButton, div [class^="cmpButton"] { display: none !important; }
  .addnew .addnew { display: none !important; }
}
